import requests, json
def emotion_detector(text_to_analyze):
    URL= 'https://sn-watson-emotion.labs.skills.network/v1/watson.runtime.nlp.v1/NlpService/EmotionPredict'
    Headers= {"grpc-metadata-mm-model-id": "emotion_aggregated-workflow_lang_en_stock"}
    Input_json={ "raw_document": { "text": text_to_analyze } }
    response=requests.post(URL,headers=Headers,json=Input_json)
    if response.status_code==400:
        scores={"joy":None,"fear":None, "sadness":None,"disgust":None,"anger":None,"dominant_emotion":None}
        return scores
    else:
        r=json.loads(response.text)
        try:
            scores=r["emotionPredictions"][0]['emotion']
            dominant_emotion=max(scores,key=scores.get)
            scores['dominant_emotion']=dominant_emotion
        except: 
            scores={"joy":None,"fear":None, "sadness":None,"disgust":None,"anger":None,"dominant_emotion":"error check response"}
        return scores