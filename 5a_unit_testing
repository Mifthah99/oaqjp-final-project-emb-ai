import unittest
from EmotionDetection import emotion_detector

class TestEmotionDetection (unittest.TestCase):
    def test_joy(self):
        r=emotion_detector("I am glad this happened")
        self.assertEqual("joy", r['dominant_emotion'])
    
    def test_anger(self):
        r=emotion_detector("I am really mad about this")
        self.assertEqual("anger", r['dominant_emotion'])
    def test_disgust(self):
        r=emotion_detector("I feel disgusted just hearing about this")
        self.assertEqual("disgust", r['dominant_emotion'])
    def test_sadness(self):
        r=emotion_detector("I am so sad about this")
        self.assertEqual("sadness", r['dominant_emotion'])
    def test_fear(self):
        r=emotion_detector("I am really afraid that this will happen")
        self.assertEqual("fear", r['dominant_emotion'])

if __name__=='__main__':
    unittest.main()        